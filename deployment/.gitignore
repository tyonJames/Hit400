# =============================================================================
# BlockLand Zimbabwe — .gitignore
# Applied at the monorepo root and within each sub-project.
# =============================================================================

# ---------------------------------------------------------------------------
# SECURITY: NEVER COMMIT THESE
# ---------------------------------------------------------------------------
.env
.env.local
.env.production
.env.staging
.env.*.local

# RSA private/public keys
*.pem
private.key
public.key
*.key

# Blockchain mnemonics (never store in files that might be committed)
mnemonic.txt
wallet.txt
*.mnemonic

# ---------------------------------------------------------------------------
# Build outputs
# ---------------------------------------------------------------------------
dist/
build/
.next/
out/

# ---------------------------------------------------------------------------
# Dependencies
# ---------------------------------------------------------------------------
node_modules/
.pnp
.pnp.js

# ---------------------------------------------------------------------------
# TypeScript
# ---------------------------------------------------------------------------
*.tsbuildinfo
*.js.map

# ---------------------------------------------------------------------------
# Testing
# ---------------------------------------------------------------------------
coverage/
.nyc_output/
playwright-report/
test-results/

# ---------------------------------------------------------------------------
# Clarinet / Stacks
# ---------------------------------------------------------------------------
.clarinet/

# ---------------------------------------------------------------------------
# Logs
# ---------------------------------------------------------------------------
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ---------------------------------------------------------------------------
# OS / Editor
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db
.idea/
.vscode/settings.json
*.swp

# ---------------------------------------------------------------------------
# Railway / Vercel / Docker
# ---------------------------------------------------------------------------
.railway/
.vercel/
