# =============================================================================
# BlockLand Zimbabwe — Backend Environment Variables (.env.example)
# =============================================================================
#
# COPY THIS FILE: cp .env.example .env
# Then fill in real values. NEVER commit the .env file to Git.
# Store secrets in Railway's Variables tab, not in code.
#
# GENERATE RSA KEY PAIR (run once, store results in Railway):
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
#   cat private.pem | base64 | tr -d '\n'   → JWT_PRIVATE_KEY
#   cat public.pem  | base64 | tr -d '\n'   → JWT_PUBLIC_KEY
#
# GENERATE TESTNET WALLET (for deployer and registrar):
#   Visit: wallet.hiro.so → Create Wallet → Save 24-word mnemonic securely
#   Fund with free testnet STX: faucet.stacks.co
# =============================================================================

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------

# Node.js environment: development | test | production
NODE_ENV=production

# Port the NestJS app listens on (Railway sets PORT automatically)
PORT=3001

# Frontend URL — used for CORS allow-list (update after Vercel deploys)
FRONTEND_URL=https://blockland.vercel.app

# ---------------------------------------------------------------------------
# Database (PostgreSQL)
# ---------------------------------------------------------------------------

# Railway PostgreSQL connection string (auto-set by Railway plugin)
# Format: postgresql://user:password@host:5432/database
DATABASE_URL=postgresql://postgres:password@monorail.proxy.rlwy.net:12345/railway

# Legacy individual fields (used by data-source.ts for migration CLI)
# Leave blank if DATABASE_URL is set — TypeORM will parse the URL
DATABASE_HOST=
DATABASE_PORT=5432
DATABASE_NAME=railway
DATABASE_USER=postgres
DATABASE_PASSWORD=

# ---------------------------------------------------------------------------
# JWT Authentication (RS256)
# ---------------------------------------------------------------------------

# Base64-encoded RSA private key (2048-bit) for signing JWT access tokens
# Generate: openssl genrsa -out private.pem 2048 && cat private.pem | base64 -w 0
JWT_PRIVATE_KEY=LS0tLS1CRUdJTiBSU0EgUFJJVkFURSBLRVktLS0tLQ==  # PLACEHOLDER

# Base64-encoded RSA public key for verifying JWT access tokens
# Generate: openssl rsa -in private.pem -pubout -out public.pem && cat public.pem | base64 -w 0
JWT_PUBLIC_KEY=LS0tLS1CRUdJTiBQVUJMSUMgS0VZLS0tLS0=  # PLACEHOLDER

# Access token expiry (short-lived for security)
JWT_ACCESS_EXPIRES_IN=15m

# Refresh token expiry (longer-lived, rotated on each use)
JWT_REFRESH_EXPIRES_IN=7d

# ---------------------------------------------------------------------------
# Stacks Blockchain
# ---------------------------------------------------------------------------

# Target network: testnet | mainnet
STACKS_NETWORK=testnet

# Stacks API base URL (Hiro public node — free for testnet)
STACKS_API_URL=https://api.testnet.hiro.so

# Deployed contract identifier: {deployer-address}.{contract-name}
# Example: ST1PQHQKV0RJXZFY1DGX8MNSNYVE3VGZJSRTPGZGM.blockland
# Set this AFTER running: clarinet deployments apply --testnet
CLARITY_CONTRACT_ADDRESS=ST_YOUR_DEPLOYER_ADDRESS.blockland

# 24-word BIP-39 mnemonic of the REGISTRAR wallet
# This wallet calls register-property, initiate-transfer etc. server-side
# CRITICAL: never expose this value; store only in Railway secret variables
REGISTRAR_MNEMONIC=word1 word2 word3 word4 word5 word6 word7 word8 word9 word10 word11 word12 word13 word14 word15 word16 word17 word18 word19 word20 word21 word22 word23 word24

# 24-word mnemonic of the DEPLOYER wallet
# Only needed for the seed.ts script; not required at runtime
DEPLOYER_MNEMONIC=word1 word2 word3 word4 word5 word6 word7 word8 word9 word10 word11 word12 word13 word14 word15 word16 word17 word18 word19 word20 word21 word22 word23 word24

# ---------------------------------------------------------------------------
# IPFS Document Storage (Pinata)
# ---------------------------------------------------------------------------

# Pinata API key and secret — from pinata.cloud/keys
PINATA_API_KEY=your_pinata_api_key_here
PINATA_SECRET_API_KEY=your_pinata_secret_key_here

# Pinata IPFS gateway for document retrieval
PINATA_GATEWAY_URL=https://gateway.pinata.cloud

# ---------------------------------------------------------------------------
# Rate Limiting (optional overrides)
# ---------------------------------------------------------------------------

# Global API rate limit per IP per minute (default: 100)
RATE_LIMIT_MAX=100

# Auth-specific rate limit per IP per minute (default: 10 — brute force protection)
AUTH_RATE_LIMIT_MAX=10
