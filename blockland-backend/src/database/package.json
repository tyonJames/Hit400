{
  "name": "blockland-backend",
  "version": "1.0.0",
  "description": "BlockLand Zimbabwe — NestJS Backend API",
  "author": "Tinotenda James",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build":               "nest build",
    "start":               "nest start",
    "start:dev":           "nest start --watch",
    "start:debug":         "nest start --debug --watch",
    "start:prod":          "node dist/main",

    "migration:generate":  "typeorm-ts-node-commonjs migration:generate -d data-source.ts",
    "migration:run":       "typeorm-ts-node-commonjs migration:run -d data-source.ts",
    "migration:revert":    "typeorm-ts-node-commonjs migration:revert -d data-source.ts",
    "migration:show":      "typeorm-ts-node-commonjs migration:show -d data-source.ts",

    "db:setup":            "psql -U postgres -c \"CREATE DATABASE blockland_db;\" && npm run migration:run",

    "test":                "jest",
    "test:watch":          "jest --watch",
    "test:cov":            "jest --coverage",
    "test:e2e":            "jest --config ./test/jest-e2e.json"
  },
  "dependencies": {
    "@nestjs/common":       "^10.0.0",
    "@nestjs/config":       "^3.0.0",
    "@nestjs/core":         "^10.0.0",
    "@nestjs/jwt":          "^10.0.0",
    "@nestjs/passport":     "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/swagger":      "^7.0.0",
    "@nestjs/typeorm":      "^10.0.0",

    "typeorm":              "^0.3.17",
    "pg":                   "^8.11.0",

    "passport":             "^0.6.0",
    "passport-jwt":         "^4.0.0",
    "bcrypt":               "^5.1.0",
    "class-validator":      "^0.14.0",
    "class-transformer":    "^0.5.1",
    "helmet":               "^7.0.0",
    "dotenv":               "^16.3.0",
    "reflect-metadata":     "^0.1.13",
    "rxjs":                 "^7.8.0"
  },
  "devDependencies": {
    "@nestjs/cli":          "^10.0.0",
    "@nestjs/schematics":   "^10.0.0",
    "@nestjs/testing":      "^10.0.0",
    "@types/bcrypt":        "^5.0.0",
    "@types/express":       "^4.17.0",
    "@types/node":          "^20.0.0",
    "@types/passport-jwt":  "^3.0.0",
    "@types/pg":            "^8.10.0",
    "ts-node":              "^10.9.0",
    "tsconfig-paths":       "^4.2.0",
    "typeorm-ts-node-commonjs": "^0.3.17",
    "typescript":           "^5.1.0"
  }
}
