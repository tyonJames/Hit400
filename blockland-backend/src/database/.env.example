# =============================================================================
# .env.example — BlockLand Zimbabwe Environment Variables
# =============================================================================
# Copy this file to .env.local for development, .env.production for production.
# NEVER commit .env.local or .env.production to version control.
# This .env.example file (with placeholder values) IS safe to commit.
#
# The NestJS ConfigModule reads from .env at startup.
# The TypeORM CLI (data-source.ts) reads via dotenv/config import.
# =============================================================================

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
NODE_ENV=development          # development | production | test
PORT=3001                     # NestJS API port

# ---------------------------------------------------------------------------
# PostgreSQL Database
# ---------------------------------------------------------------------------
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=blockland_db
DATABASE_USER=postgres
DATABASE_PASSWORD=your_secure_password_here

# ---------------------------------------------------------------------------
# JWT Authentication (RS256 — asymmetric key pair)
# These are BASE64-encoded versions of the RSA key files.
# Generate with:
#   openssl genrsa -out private.key 2048
#   openssl rsa -in private.key -pubout -out public.key
#   base64 -i private.key | tr -d '\n' > private.key.b64
#   base64 -i public.key  | tr -d '\n' > public.key.b64
# ---------------------------------------------------------------------------
JWT_PRIVATE_KEY_BASE64=your_base64_encoded_rsa_private_key
JWT_PUBLIC_KEY_BASE64=your_base64_encoded_rsa_public_key
JWT_ACCESS_TOKEN_EXPIRY=15m    # 15 minutes — short-lived access tokens
JWT_REFRESH_TOKEN_EXPIRY=7d    # 7 days — refresh tokens stored in DB

# ---------------------------------------------------------------------------
# Stacks Blockchain Integration
# ---------------------------------------------------------------------------
STACKS_API_URL=https://api.testnet.hiro.so   # Testnet. Change for mainnet.
STACKS_NETWORK=testnet                        # testnet | mainnet | devnet
CONTRACT_ADDRESS=ST1PQHQKV0RJXZFY1DGX8MNSNYVE3VGZJSRTPGZGM
CONTRACT_NAME=blockland
DEPLOYER_PRIVATE_KEY=your_deployer_private_key_hex   # NEVER COMMIT
REGISTRAR_PRIVATE_KEY=your_registrar_private_key_hex # NEVER COMMIT

# ---------------------------------------------------------------------------
# IPFS / Pinata Document Storage
# ---------------------------------------------------------------------------
PINATA_API_KEY=your_pinata_api_key
PINATA_SECRET_API_KEY=your_pinata_secret_key
PINATA_GATEWAY_URL=https://gateway.pinata.cloud

# ---------------------------------------------------------------------------
# Frontend Origin (for CORS whitelist)
# ---------------------------------------------------------------------------
FRONTEND_URL=http://localhost:3000   # Next.js dev server. Change for production.
